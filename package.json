    "format:check": "prettier --check .",
    "check": "npm run lint && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "three": "0.160.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.1",
    "globals": "^15.15.0",
    "prettier": "^3.5.1",
    "vite": "^5.4.11"
  }
}
