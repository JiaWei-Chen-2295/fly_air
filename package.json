{
  "name": "fly-air",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cinematic mobile 3D aircraft takeoff demo built with Three.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
